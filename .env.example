# RentOwl environment variables
# Copy to apps/web/.env.local for local dev. Production values live in the
# Vercel dashboard; Edge Function secrets live in Supabase secrets.
# Never commit real values.

# ── Supabase (required from M1-W1-02) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used for admin operations (e.g. confirming E2E test users).
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (required from M1-W3) ───────────────────────────────
ANTHROPIC_API_KEY=

# ── WhatsApp via 360dialog (required from M2-W2) ──────────────────
WHATSAPP_API_KEY=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_PHONE_NUMBER_ID=

# ── Stripe (required from M4-W2) ──────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Resend transactional email (required from M4-W4) ──────────────
RESEND_API_KEY=

# ── PostHog analytics (required from M4) ──────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ── Sentry (wire up when error volume justifies it) ───────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── App config ────────────────────────────────────────────────────
# "open" or "waitlist" — controls public signup mode (M4-W3-03)
SIGNUP_MODE=open
# Where the in-product feedback button sends pilot feedback (M1-W4-03).
NEXT_PUBLIC_FEEDBACK_EMAIL=feedback@rentowl.sg
